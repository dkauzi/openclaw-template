# Required
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Model (optional — defaults to claude-haiku-4-5)
OPENCLAW_MODEL=anthropic/claude-haiku-4-5-20251001

# Connect a channel (add at least one)
DISCORD_BOT_TOKEN=         # Discord bot token from discord.com/developers
TELEGRAM_TOKEN=            # Telegram bot token from @BotFather
SLACK_BOT_TOKEN=           # Slack bot OAuth token

# DeployInfra.AI integration (optional)
DISCORD_API_SECRET=        # Your DeployInfra.AI Discord API secret
